      <column caption='Hour AMPM' datatype='string' name='[Calculation_1830183783809026]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Hour] = 0 THEN &quot;12 AM&quot;&#13;&#10;ELSEIF [Hour] &lt; 12 THEN STR([Hour]) + &quot; AM&quot;&#13;&#10;ELSEIF [Hour] = 12 THEN &quot;12 PM&quot;&#13;&#10;ELSE STR([Hour]-12) + &quot; PM&quot;&#13;&#10;END' />
      </column>
      <column caption='Title Year' datatype='string' name='[Calculation_1830183812661252]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF MIN([Year]) = MAX([Year]) THEN&#13;&#10;STR(MIN([Year]))&#13;&#10;ELSE&#13;&#10;STR(MIN([Year])) + &quot; - &quot; + STR(MAX([Year]))&#13;&#10;END' />
      </column>
